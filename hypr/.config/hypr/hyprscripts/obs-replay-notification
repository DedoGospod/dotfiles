#!/usr/bin/env bash

# Identify the OBS process
OBS_PROC=$(pgrep -x "obs" || pgrep -x ".obs-wrapped")

if [[ -n "$OBS_PROC" ]]; then
    ICON="/usr/share/icons/hicolor/256x256/apps/com.obsproject.Studio.png"
    if obs-cmd replay save; then
        notify-send -h boolean:SWAYNC_BYPASS_DND:true -i "$ICON" -t 1000 "Replay Saved" "OBS Buffer Captured"
    fi
else
    notify-send -t 1500 "⚠️  OBS Error" "OBS is not running"
fi
