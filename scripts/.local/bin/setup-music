#!/usr/bin/env bash

# Colors for logging
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

# Helper Functions
header() { echo -e "\n${BLUE}==== $1 ====${NC}"; }
log() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }

log_task() { echo -ne "${GREEN}[INFO]${NC} $1... "; }
ok() { echo -e "${GREEN}Done.${NC}"; }
fail() { echo -e "${RED}Failed.${NC}"; }

# Grant sudo permissions early
sudo -v

# Package list
PACKAGES=(yt-dlp rmpc mpd mpc python-mutagen)
mapfile -t MISSING_PACKAGES < <(pacman -T "${PACKAGES[@]}")

# Install missing packages
if [[ ${#MISSING_PACKAGES[@]} -gt 0 ]]; then
    log_task "Installing missing packages: ${MISSING_PACKAGES[*]}"
    sudo pacman -S --needed --noconfirm "${MISSING_PACKAGES[@]}" >/dev/null
    ok
else
    log_task "Music packages are already installed"
    ok
fi

# Enable mpd service
if ! systemctl is-enabled mpd.service >/dev/null; then
    log_task "Enabling mpd.service"
    systemctl enable --now mpd.service
    ok
else
    log_task "mpd service already active"
    ok
fi

# Stow dotfiles
DOT_DIR="$HOME/dotfiles"
if [[ -d "$DOT_DIR" ]]; then
    cd "$DOT_DIR" && stow music
fi
