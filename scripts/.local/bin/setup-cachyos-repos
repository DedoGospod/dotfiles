#!/usr/bin/env bash

echo "--- Initializing CachyOS Repository Setup ---"
curl https://mirror.cachyos.org/cachyos-repo.tar.xz -o cachyos-repo.tar.xz
tar xvf cachyos-repo.tar.xz && cd cachyos-repo
sudo ./cachyos-repo.sh

# Kernel Management Logic
echo "--- Kernel Management ---"

# Update databases to see the new CachyOS packages
sudo pacman -Sy

read -rp "Install the CachyOS optimized kernel? (y/N): " install_cachy
if [[ "$install_cachy" =~ ^[Yy]$ ]]; then
    sudo pacman -S --needed --noconfirm linux-cachyos linux-cachyos-headers
    
    # Prompt to remove generic kernel
    read -rp "Remove the generic Arch kernel? (y/N): " remove_generic
    if [[ "$remove_generic" =~ ^[Yy]$ ]]; then
        sudo pacman -Rns --noconfirm linux linux-headers
    fi
fi

echo "--- Setup Complete ---"
