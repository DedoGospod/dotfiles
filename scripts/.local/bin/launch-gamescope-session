#!/usr/bin/env bash

# Monitor settings (Physical Output)
WIDTH=2560
HEIGHT=1440
REFRESH=240

# Graceful steam shutdown
if pgrep -u "$USER" -x steam >/dev/null; then
    echo "Steam is running. Requesting graceful shutdown..."
    pkill -15 -u "$USER" -x steam

    # Wait up to 15 seconds for cloud syncs and graceful exit
    for _ in {1..30}; do
        pgrep -u "$USER" -x steam >/dev/null || break
        sleep 0.5
    done

    # Force kill if it hung, to ensure TTY2 can boot
    if pgrep -u "$USER" -x steam >/dev/null; then
        pkill -9 -u "$USER" -x steam
    fi
fi

for lockfile in "/tmp/steam.pid" "/tmp/dumps/steam_message_log.txt"; do
    if [[ -f "$lockfile" && -O "$lockfile" && ! -L "$lockfile" ]]; then
        rm "$lockfile"
    fi
done

GAMESCOPE_OPTS=(
    # Display
    --fullscreen
    --immediate-flips
    --adaptive-sync
    -W "$WIDTH"
    -H "$HEIGHT"
    -r "$REFRESH"

    # Input
    --hide-cursor-delay 3000
    --force-grab-cursor
    --grab

    # Integration
    --steam
    --mangoapp

    # Real time scheduling
    --rt

    # HDR
    --hdr-enabled
    --hdr-itm-enabled
    --hdr-sdr-content-nits 100
    --hdr-itm-target-nits 400
    --sdr-gamut-wideness 1
)

# Steam options
STEAM_OPTS=(
    -gamepadui
    -steamos3

    -steampal
    -steamdeck
)

# Embedded mode options
if ! [[ -z "$WAYLAND_DISPLAY" ]] && [[ -z "$DISPLAY" ]]; then
    GAMESCOPE_OPTS+=(
        --backend=drm
    )
fi

# Start gamescope instance
if command -v gamescope >/dev/null; then
    exec gamescope "${GAMESCOPE_OPTS[@]}" -- steam "${STEAM_OPTS[@]}"
else
    echo "Error: gamescope binary not found. Please install it." >&2
    exit 1
fi
