#!/usr/bin/env bash

# Track state for cleanup
OBS_STARTED_BY_SCRIPT=0

# Helper to run commands only if they exist
run_if_exists() {
    if command -v "$1" >/dev/null; then
        "$@"
    fi
}

# Cleanup function
cleanup() {
    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then

        # Reset hyprland, notifications and stop the replay buffer
        run_if_exists hyprctl reload
        run_if_exists swaync-client -df
        run_if_exists obs-cmd replay stop

        # Stop the OBS service only if this script started it
        if [[ "$OBS_STARTED_BY_SCRIPT" -eq 1 ]]; then
            systemctl --user stop obs.service
        fi

        # Reset blue light filter and brightness
        if ! pgrep -x "hyprsunset" >/dev/null; then
            systemctl --user start hyprsunset.service
        fi
        run_if_exists hyprctl hyprsunset gamma 50
    fi
}

# Cleanup trap
trap cleanup EXIT INT TERM HUP QUIT

main() {
    # Check if we are in hyprland
    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then

        # Enable performance mode
        run_if_exists hyprctl --batch "\
            keyword animations:enabled 0;\
            keyword animation borderangle,0; \
            keyword decoration:shadow:enabled 0;\
            keyword decoration:blur:enabled 0;\
            keyword decoration:fullscreen_opacity 1;\
            keyword general:gaps_in 0;\
            keyword general:gaps_out 0;\
            keyword general:border_size 1;\
            keyword decoration:rounding 0"

        # Stop notifications
        run_if_exists swaync-client -dn

        # Start OBS if it's not already running
        if ! pgrep -x "obs" >/dev/null; then
            systemctl --user start obs.service
            OBS_STARTED_BY_SCRIPT=1
        fi
        run_if_exists obs-cmd replay start

        # Disable blue light filter and maximize brightness
        if pgrep -x "hyprsunset" >/dev/null; then
            systemctl --user stop hyprsunset.service
        fi
        run_if_exists hyprctl hyprsunset gamma 100
    fi

    # Run the game
    if command -v scopebuddy >/dev/null; then
        scopebuddy -- "$@"
    else
        "$@"
    fi
}

# Pass all script arguments into main
main "$@"
