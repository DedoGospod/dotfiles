#!/usr/bin/env bash

# Colors for logging
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

# Helper Functions
header() { echo -e "\n${BLUE}==== $1 ====${NC}"; }
log() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }

log_task() { echo -ne "${GREEN}[INFO]${NC} $1... "; }
ok() { echo -e "${GREEN}Done.${NC}"; }
fail() { echo -e "${RED}Failed.${NC}"; }

sudo -v

CONF_FILE="/etc/modules-load.d/i2c.conf"
SETTING="i2c-dev"

# Install if needed
if ! command -v ddcutil >/dev/null; then
    sudo pacman -S --needed --noconfirm ddcutil
fi

if echo "$SETTING" | sudo tee "$CONF_FILE" >/dev/null; then
    log_task "Configuring i2c"
    sudo modprobe i2c-dev
    ok
fi

if command -v usermod >/dev/null; then
    log_task "Setting permissions"
    sudo usermod -aG i2c "$USER"
    ok
fi

success "ddcutil setup complete"
