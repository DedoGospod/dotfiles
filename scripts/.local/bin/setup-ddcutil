#!/usr/bin/env bash

# Ensure script isnt run as root
if [[ "$EUID" -eq 0 ]]; then
    echo "Please do not run this script as root."
    echo "Run it as a normal user. You will be prompted for sudo password when needed."
    exit 1
fi

sudo -v

CONF_FILE="/etc/modules-load.d/i2c.conf"
SETTING="i2c-dev"

uninstall_ddcutil() {
    echo "Removing ddcutil package..."
    sudo pacman -Rns --noconfirm ddcutil

    echo "Removing i2c user group..."
    if getent group i2c >/dev/null 2>&1; then
        sudo groupdel i2c
    fi

    echo "Cleaning up config files"
    sudo rm -rf "$CONF_FILE"

    echo "ddcutil has been completely removed and config reset."
    echo "Note: You may need to log out and back in to refresh your user groups."
}

install_ddcutil() {
    echo "Installing the ddcutil package"
    if ! command -v ddcutil >/dev/null; then
        sudo pacman -S --needed --noconfirm ddcutil
    fi

    echo "Creating the i2c configuration file"
    if echo "$SETTING" | sudo tee "$CONF_FILE" >/dev/null; then
        sudo modprobe i2c-dev
    fi

    echo "Adding $USER to i2c group"
    sudo usermod -aG i2c "$USER"

    echo "ddcutil setup complete"
}

# Check for arguments
case "$1" in
--uninstall)
    uninstall_ddcutil
    ;;
*)
    install_ddcutil
    ;;
esac
