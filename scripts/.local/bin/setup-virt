#!/usr/bin/env bash

# Colors for logging
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

# Helper Functions
header() { echo -e "\n${BLUE}==== $1 ====${NC}"; }
log() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }

log_task() { echo -ne "${GREEN}[INFO]${NC} $1... "; }
ok() { echo -e "${GREEN}Done.${NC}"; }
fail() { echo -e "${RED}Failed.${NC}"; }

ask() {
    read -rp "$(echo -e "  ${YELLOW}??${NC} $1 (y/N): ")" response
    [[ "$response" =~ ^[Yy]$ ]]
}

# Package list
PACMAN_PACKAGES=(qemu-full virt-manager dnsmasq swtpm)
mapfile -t MISSING_PACKAGES < <(pacman -T "${PACMAN_PACKAGES[@]}")

services=("virtqemud.socket" "virtqemud-ro.socket" "virtqemud-admin.socket" "virtnetworkd.socket" "virtstoraged.socket" "virtlogd.socket" "virtlockd.socket")
group="libvirt"
net="default"

setup_virt() {
    # Install any missing packages
    if [[ ${#MISSING_PACKAGES[@]} -gt 0 ]]; then
        log_task "Installing missing packages: ${MISSING_PACKAGES[*]}"
        sudo pacman -S --needed --noconfirm "${MISSING_PACKAGES[@]}" >/dev/null
        ok
    fi

    # Add user to libvirt group
    if id -nG "$USER" | grep -qw "$group"; then
        log_task "User already in $group"
        ok
    else
        log_task "Adding $USER to $group"
        if sudo usermod -aG "$group" "$USER"; then
            touch /tmp/reboot_required
            ok
        else
            error "Failed to add user to group."
            exit 1
        fi
    fi

    # Enable services
    for svc in "${services[@]}"; do
        if systemctl is-active --quiet "$svc"; then
            log_task "$svc is already running"
            ok
        else
            log_task "Starting $svc..."
            sudo systemctl enable --now "$svc"
            ok
        fi
    done

    # Network start
    if ! sudo virsh net-list --all | grep -q "$net"; then
        log_task "Creating default network from template..."
        sudo virsh net-define /etc/libvirt/qemu/networks/default.xml
        ok
    fi

    # Start default network if its down
    sudo virsh net-start "$net" >/dev/null

    # Set default network to autostart
    sudo virsh net-autostart "$net" >/dev/null

    # Check if reboot is required
    if [[ -f /tmp/reboot_required ]]; then
        rm /tmp/reboot_required
        if ask "System changes detected. Reboot now?"; then
            log "Rebooting..."
            sudo reboot
        else
            warn "Please reboot manually to apply changes."
        fi
    else
        log "No system changes require a reboot. Enjoy!"
    fi
}

uninstall_virt() {
    # Clean up libvirt objects
    if sudo virsh net-list --all | grep -q "$net"; then
        log_task "Disabling autostart for network: $net..."
        sudo virsh net-autostart "$net" --disable >/dev/null || true
        ok

        # Check if network is active before trying to destroy it
        if sudo virsh net-list --state-active | grep -q "$net"; then
            log_task "Stopping active network: $net..."
            sudo virsh net-destroy "$net" >/dev/null || true
            ok
        fi

        # Remove network
        log_task "Removing network definition: $net..."
        sudo virsh net-undefine "$net" >/dev/null || true
        ok
    else
        warn "Network $net does not exist. Nothing to revert."
    fi

    # Stop and disable services
    log "Stopping and disabling libvirt services"
    for svc in "${services[@]}"; do
        if systemctl is-active --quiet "$svc"; then
            log_task "Stopping/disabling $svc..."
            sudo systemctl stop "$svc"
            sudo systemctl disable "$svc"
            ok
        fi
    done

    # Clean up system groups
    if getent group "$group" >/dev/null; then
        log_task "Removing user groups"
        sudo groupdel "$group"
        ok
    fi

    # Remove packages
    log_task "Removing virtualization packages: ${PACMAN_PACKAGES[*]}"
    sudo pacman -Rns --noconfirm "${PACMAN_PACKAGES[@]}" >/dev/null
    ok
}

# Check for arguments
case "$1" in
--uninstall)
    uninstall_virt
    ;;
*)
    setup_virt
    ;;
esac
