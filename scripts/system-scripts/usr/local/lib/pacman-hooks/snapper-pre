#!/usr/bin/env bash
set -euo pipefail

#Configuration
SECURE_DIR="/run/snapper-hooks"
CRITICAL_PKGS=(
    "linux*"
    "systemd*"
    "*nvidia*"
    "mesa*"
    "grub*"
    "mkinitcpio*"
    "glibc*"
    "pacman*"
    "*ucode"
)

# Setup
[[ ! -d "$SECURE_DIR" ]] && mkdir -p "$SECURE_DIR" && chmod 700 "$SECURE_DIR"
STATE_FILE=$(mktemp -p "$SECURE_DIR" "snapper-pre-${PPID}.XXXXX")
TYPE="routine"
PKGS=()

# Detection with Pattern Matching
while read -r pkg_line; do
    pkg_name=$(echo "$pkg_line" | awk '{print $1}')
    [[ -z "$pkg_name" ]] && continue
    PKGS+=("$pkg_name")

    # Check against critical patterns
    for pattern in "${CRITICAL_PKGS[@]}"; do
        # shellcheck disable=SC2254
        case "$pkg_name" in
            $pattern)
                TYPE="important"
                ;;
        esac
    done
done

# Metadata Construction
if [[ "$TYPE" == "important" ]]; then
    DESC="[CRITICAL] Important Update"
    EXTRA_ARGS=(--userdata "important=yes")
else
    DESC="Routine"
    EXTRA_ARGS=()
fi

# Execution
snapper create -t pre -c number -d "$DESC" "${EXTRA_ARGS[@]}" -p >"$STATE_FILE"
