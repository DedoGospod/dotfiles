#!/usr/bin/env bash
set -euo pipefail

# Configuration
SECURE_DIR="/run/snapper-hooks"
CRITICAL_PKGS=(
    "linux*"
    "systemd*"
    "*nvidia*"
    "mesa*"
    "grub*"
    "mkinitcpio*"
    "glibc*"
    "pacman*"
    "*ucode"
)

# Setup
mkdir -p "$SECURE_DIR"
chmod 700 "$SECURE_DIR"
STATE_FILE=$(mktemp -p "$SECURE_DIR" "snapper-pre-${PPID}.XXXXX")
TYPE="routine"

# Cleanup trap: Remove STATE_FILE if the script fails before snapper completes
trap '[[ $? -ne 0 ]] && rm -f "$STATE_FILE"' EXIT

# Capture the exact command that triggered this hook (pacman, yay, paru, etc.)
if [[ -r "/proc/$PPID/cmdline" ]]; then
    PARENT_CMD=$(tr '\0' ' ' < "/proc/$PPID/cmdline" | sed 's/[[:space:]]*$//')
else
    PARENT_CMD="Unknown Command"
fi

# Truncate PARENT_CMD if it is long to preserve 'snapper list' formatting
if (( ${#PARENT_CMD} > 80 )); then
    PARENT_CMD="${PARENT_CMD:0:77}..."
fi

# Detection with Pattern Matching (Optimized: No awk forks)
while read -r pkg_name _; do
    [[ -n "$pkg_name" ]] || continue

    # Check against critical patterns
    for pattern in "${CRITICAL_PKGS[@]}"; do
        # shellcheck disable=SC2053
        if [[ "$pkg_name" == $pattern ]]; then
            TYPE="important"
            break 2
        fi
    done
done

# Metadata Construction
if [[ "$TYPE" == "important" ]]; then
    DESC="[CRITICAL] $PARENT_CMD"
    EXTRA_ARGS=(--userdata "important=yes")
else
    DESC="[Routine] $PARENT_CMD"
    EXTRA_ARGS=()
fi

# Execution
snapper create -t pre -c number -d "$DESC" "${EXTRA_ARGS[@]}" -p >"$STATE_FILE"
