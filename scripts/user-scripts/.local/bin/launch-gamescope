#!/usr/bin/env bash

# Performance & Display Environment Variables
export DXVK_HDR=1
export ENABLE_GAMESCOPE_WSI=1
export GAMESCOPE_NV12_COLORSPACE=1

GAMESCOPE_OPTS=(
  # Resolution & Display
  -w 2560
  -h 1440
  -r 240
  --fullscreen
  
  # Latency & Input
  --immediate-flips
  --force-grab-cursor
  --adaptive-sync
  
  # HDR Specifics
  --hdr-enabled
  --hdr-itm-enable
  --hdr-wide-gamut
  
)

# Launching the game
gamescope "${GAMESCOPE_OPTS[@]}" -- steam
