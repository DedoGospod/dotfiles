#!/usr/bin/env bash

# Monitor resolution
WIDTH=2560
HEIGHT=1440

GAMESCOPE_OPTS=(
    # Display
    --fullscreen
    --immediate-flips
    --nested-refresh 240
    -W "$WIDTH"
    -H "$HEIGHT"

    # Upscaling
    --scaler auto
    --filter fsr
    --fsr-sharpness 2

    # Input
    --hide-cursor-delay 3000
    --force-grab-cursor
    --grab

    # Integration
    --steam
    --rt
    --mangoapp
    --backend=drm

    # HDR Pipeline
    --hdr-enabled
    --hdr-itm-enabled
    --hdr-sdr-content-nits 100
    --hdr-itm-target-nits 400
    --sdr-gamut-wideness 1
)

exec gamescope "${GAMESCOPE_OPTS[@]}" -- steam -gamepadui -tenfoot -steamos3
