#!/usr/bin/env bash

# Remember whether we started OBS
OBS_STARTED_BY_SCRIPT=0

# Start OBS if it isn't running
if ! pgrep -x "obs" > /dev/null; then
    systemctl --user start obs.service
    sleep 2
    OBS_STARTED_BY_SCRIPT=1
fi

# Set brightness to 100% for duration of game
if command -v hyprsunset; then
    hyprctl hyprsunset gamma 100
fi

# Start Replay Buffer
if command -v obs-cmd; then
    obs-cmd replay start
fi

# Run the game via scopebuddy
if command -v scb; then
    scopebuddy -- "$@"
fi

# Cleanup after game exits
if command -v obs-cmd >/dev/null; then
    obs-cmd replay stop
    if [[ "$OBS_STARTED_BY_SCRIPT" -eq 1 ]]; then
        systemctl --user stop obs.service
    fi
fi

# Reset brightness
if command -v hyprsunset; then
    hyprctl hyprsunset gamma 75
fi
