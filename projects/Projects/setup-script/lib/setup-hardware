#!/usr/bin/env bash

# Colors for logging
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

# Helper Functions
header() { echo -e "\n${BLUE}==== $1 ====${NC}"; }
log() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }

log_task() { echo -ne "${GREEN}[INFO]${NC} $1... "; }
ok() { echo -e "${GREEN}Done.${NC}"; }
fail() { echo -e "${RED}Failed.${NC}"; }

# NVIDIA Configuration Block
header "HARDWARE CONFIGURATION"

# Ensure chwd is installed first
if ! command -v chwd &>/dev/null; then
    log_task "chwd not found. Installing"
    if sudo pacman -S --needed --noconfirm chwd; then
        ok
    else
        fail
        error "Failed to install chwd"
        exit 1
    fi
fi

log_task "Syncing drivers with chwd"
if command -v chwd >/dev/null; then
    chwd -a >/dev/null
    ok
else
    fail
fi

# Nvidia utilities
if lspci | grep -iq "nvidia"; then
    log_task "Installing NVIDIA utilities"
    NVIDIA_PACKAGES=(nvidia-settings egl-wayland libva-nvidia-driver)
    MISSING_PACKAGES=()

    # Check if packages exist on system
    for pkg in "${NVIDIA_PACKAGES[@]}"; do
        if ! pacman -Qq "$pkg" &>/dev/null; then
            MISSING_PACKAGES+=("$pkg")
        fi
    done
    ok

    GRUB_FILE="/etc/default/grub"
    PARAM="nvidia-drm.modeset=1 nvidia-drm.fbdev=1"

    if [[ -f "$GRUB_FILE" ]] && ! grep -q "nvidia-drm.modeset=1" "$GRUB_FILE"; then
        log_task "Adding KMS parameters to GRUB"
        sudo sed -i "/GRUB_CMDLINE_LINUX_DEFAULT/ s/\"$/ $PARAM\"/" "$GRUB_FILE"
        sudo grub-mkconfig -o /boot/grub/grub.cfg
        touch /tmp/reboot_required
        ok
    fi
fi

success "Hardware is synced and optimized."
