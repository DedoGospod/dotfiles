#!/usr/bin/env bash

# Exit immediately if a command exits with a non-zero status
set -e
set -o pipefail

# Colors for logging
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

# Helper Functions
header() { echo -e "\n${BLUE}==== $1 ====${NC}"; }
log() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }

log_task() { echo -ne "${GREEN}[INFO]${NC} $1... "; }
ok() { echo -e "${GREEN}Done.${NC}"; }
fail() { echo -e "${RED}Failed.${NC}"; }

# Task runner
run_task() {
    log_task "$1"
    shift

    local err_log
    err_log=$(mktemp)

    if "$@" 2>"$err_log" >/dev/null; then
        ok
    else
        fail
        [[ -s "$err_log" ]] && error "$(cat "$err_log")"
    fi
    rm -f "$err_log"
}

# Function to detect bootloader
detect_bootloader() {
    if [[ -d "/boot/grub" ]] || command -v grub-install >/dev/null; then
        echo "grub"
    elif [[ -d "/boot/limine" ]] || [[ -f "/boot/limine.conf" ]] || [[ -f "/boot/EFI/limine/limine.conf" ]]; then
        echo "limine"
    else
        echo "unknown"
    fi
}

header "BTRFS SETUP"

BOOTLOADER=$(detect_bootloader)
log "Detected bootloader: $BOOTLOADER"

# Initialize core packages and systemd services arrays
PACKAGES=(btrfsmaintenance snapper snap-pac snapper-rollback inotify-tools)
btrfs_units=(
    "snapper-timeline.timer"
    "snapper-cleanup.timer"
    "btrfs-scrub.timer"
    "btrfs-balance.timer"
)

# Append bootloader dependencies BEFORE evaluating missing packages
if [[ "$BOOTLOADER" == "grub" ]]; then
    PACKAGES+=(grub-btrfs)
    btrfs_units+=("grub-btrfsd.service")
elif [[ "$BOOTLOADER" == "limine" ]]; then
    PACKAGES+=(limine-snapper-sync limine-mkinitcpio-hook)
    btrfs_units+=("limine-snapper-watcher.service" "limine-snapper-sync.service")
fi

# Evaluate missing packages now that the array is complete
mapfile -t MISSING_PACKAGES < <(pacman -T "${PACKAGES[@]}")

# Identify the root Btrfs device
ROOT_DEV=$(findmnt -v -n -o SOURCE /)
ROOT_UUID=$(lsblk -dno UUID "$ROOT_DEV")
log "Detected Root Device: $ROOT_DEV (UUID: $ROOT_UUID)"

# Securely provision the rollback directory atomically
log_task "Provisioning /btrfsroot"
sudo install -d -m 0700 /btrfsroot
ok

# Mount top-level Btrfs volume to manipulate subvolumes
log_task "Mounting top-level Btrfs volume"
sudo mount -t btrfs -o subvolid=5 "$ROOT_DEV" /btrfsroot
ok

# Create the flat @snapshots subvolume if it does not exist
if [[ ! -d "/btrfsroot/@snapshots" ]]; then
    log_task "Creating @snapshots flat subvolume"
    sudo btrfs subvolume create /btrfsroot/@snapshots >/dev/null
    ok
else
    log "@snapshots subvolume already exists."
fi

# Unmount top-level volume immediately after structural subvolume task
sudo umount /btrfsroot

# Establish and mount the flat layout path
if findmnt /.snapshots >/dev/null; then
    log "/.snapshots is already mounted properly."
else
    # Safety check: If an accidental nested subvolume was initialized, clear it
    if [[ -d "/.snapshots" ]] && btrfs subvolume show /.snapshots &>/dev/null; then
        log_task "Purging accidental nested subvolume at /.snapshots"
        sudo btrfs subvolume delete /.snapshots >/dev/null
        ok
    fi
    
    log_task "Mounting flat @snapshots subvolume to /.snapshots"
    sudo mkdir -p /.snapshots
    sudo mount -t btrfs -o subvol=@snapshots "$ROOT_DEV" /.snapshots
    sudo chmod 750 /.snapshots
    ok
fi

# Configure snapper-rollback
log_task "Configuring /etc/snapper-rollback.conf"
cat <<EOF | sudo tee /etc/snapper-rollback.conf >/dev/null
[root]
subvol_main = @
subvol_snapshots = @snapshots
mountpoint = /btrfsroot
dev = /dev/disk/by-uuid/$ROOT_UUID
EOF
ok

# Persist the flat snapshot layout inside fstab
if ! grep -q "/.snapshots" /etc/fstab; then
    log_task "Persisting /.snapshots mount in /etc/fstab"
    echo "UUID=$ROOT_UUID /.snapshots btrfs subvol=@snapshots,rw,noatime,compress=zstd 0 0" | sudo tee -a /etc/fstab >/dev/null
    ok
fi

# Install missing system packages
if [[ ${#MISSING_PACKAGES[@]} -gt 0 ]]; then
    log_task "Installing missing packages: ${MISSING_PACKAGES[*]}"
    sudo pacman -S --needed --noconfirm "${MISSING_PACKAGES[@]}" >/dev/null
    ok
fi

# Enable all systemd units
run_task "Enabling Btrfs and Snapper systemd units" sudo systemctl enable --now "${btrfs_units[@]}"
