#!/usr/bin/env zsh

# ga: Stage files (defaults to all) and show status
ga() {
    git add "${@:-.}"
    git status
}

gm() {
    local target_branch="${1:-main}"
    local source_branch="${2:-testing}"
    local original_branch
    original_branch=$(git symbolic-ref --short HEAD 2>/dev/null)

    (
        if ! git diff-index --quiet HEAD --; then
            error "You have uncommitted changes. Stash or commit them first." >&2
            exit 1
        fi

        log_task "Switching to ${target_branch} and syncing..."
        git switch "$target_branch"
        git pull --rebase origin "$target_branch"

        log "Merging '${source_branch}' into '${target_branch}'..."
        git merge "$source_branch"

        log "Pushing updates..."
        git push origin "$target_branch"

        log "Returning to ${original_branch}..."
        git switch "$original_branch"
    )
}

git-reset-hard() {
  local current_branch=$(git rev-parse --abbrev-ref HEAD)
  local upstream=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)
  local target=${upstream:-"origin/main"}

  warn "This will destroy all local changes on '$current_branch'."
  log "Resetting to $target..."
  
  # Ask for confirmation
  read -q "choice?Are you sure? (y/n) "
  echo ""
  if [[ "$choice" == "y" ]]; then
      git reset --hard "$target"
  else
      log "Reset aborted."
  fi
}
