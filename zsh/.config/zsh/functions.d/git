#!/usr/bin/env zsh

# ga: Stage files (defaults to all) and show status
ga() {
    git add "${@:-.}"
    git status
}

gm() {
    (
        set -e

        if ! git diff-index --quiet HEAD --; then
            error "You have uncommitted changes. Stash or commit them first."
            return 1
        fi

        log_task "Switching to main and syncing..."
        git checkout main
        git pull --rebase origin main
        ok

        log_task "Merging 'testing' into 'main'..."
        if ! GIT_MERGE_AUTOEDIT=no git merge testing --no-edit; then
            echo "Merge conflict detected! Stopping."
            return 1
        fi
        ok

        log_task "Pushing updates..."
        git push origin main
        ok

        log_task "Returning to testing branch..."
        git checkout testing
        ok
    )
}

git-reset-hard() {
  # Get the name of the current branch
  local current_branch=$(git rev-parse --abbrev-ref HEAD)
  # Get the remote tracking branch (e.g., origin/feature-x)
  local upstream=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)

  # Fallback to origin/main if no upstream is set
  local target=${upstream:-"origin/main"}

  echo "Warning: This will destroy all local changes on '$current_branch'."
  echo "Resetting to $target..."
  
  # Optional: Ask for confirmation
  read -q "choice?Are you sure? (y/n) "
  echo ""
  if [[ "$choice" == "y" ]]; then
      git reset --hard "$target"
  else
      log "Reset aborted."
  fi
}
