#!/usr/bin/env zsh
    
if (( $+commands[paru] )) && (( $+commands[fzf] )); then
    s() {
        paru -Slq | grep -E '^[a-z0-9@._+-]+$' | fzf \
            --query "$1" \
            --multi \
            --ansi \
            --layout=reverse \
            --border=rounded \
            --info=inline \
            --tiebreak=begin,length \
            --header "─── [Enter]: Install | [TAB]: Select | [CTRL-A]: Select All ───" \
            --header-first \
            --prompt="󰈺 Search: " \
            --pointer="▶" \
            --marker="✓" \
            --color="header:italic:cyan,border:blue" \
            --preview '[[ -n {} ]] && paru -Si {} --color=always' \
            --preview-window='right:60%:wrap:border-left' \
            --bind 'enter:become(paru -S {+})' \
            --bind 'ctrl-a:select-all'
        }
fi
