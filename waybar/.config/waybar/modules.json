{
  "custom/arch": {
    "format": "ґ░гЗ",
    "tooltip": false,
    "on-click": ""
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "warp-on-scroll": false,
    "format": "{name}",
    "format-icons": {
      "urgent": "яБк",
      "active": "яЖТ",
      "default": "яДС"
    }
  },
  "mpris": {
    "player": "playerctld",
    "format": "{player_icon} {dynamic}",
    "format-paused": "{player_icon} <i>{dynamic}</i>",
    "dynamic-order": ["title", "artist"],
    "max-length": 40,
    "player-icons": {
      "spotify": "яЖ╝",
      "firefox": "яЙй",
      "default": "тЩк"
    },
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "яСж",
    "format-icons": {
      "default": ["яАж", "яАз", "яАи"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "io.github.ebonjaeger.bluejay"
  },
  "network": {
    "format-wifi": "<span size='13000' foreground='#f5e0dc'>яЗл</span> {essid}",
    "format-ethernet": "<span size='13000' foreground='#f5e0dc'></span> Ethernet",
    "format-disconnected": "<span size='13000' foreground='#f5e0dc'>тЪа</span> Disconnected",
    "tooltip-format-wifi": "Signal Strength: {signalStrength}%",
    "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}",
    "on-click": "nm-applet"
  },
  "cpu": {
    "format": "яЛЫ {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "яГЙ {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
    "critical-threshold": 100,
    "format-critical": "яЛЗ {temperatureC}",
    "format": "яЛЙ {temperatureC}┬░C"
  },
  "hyprland/language": {
    "format": "яВм {}",
    "format-en": "EN",
    "format-ru": "RU"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-charging": "яЧз {capacity}%",
    "format-plugged": "яЗж {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "clock": {
    "format": "<span foreground='#f5c2e7' font_size='smaller'>яАЧ</span> {:%a %d %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather",
    "return-type": "json",
    "interval": 1800,
    "format": "{}"
  }
}
